# Environments & Envs
.venv/
.env
.env.*

# Python Cache & Byte-compiled
__pycache__/
*.py[codz]
*$py.class
*.so

# MacOS / OS specific
.DS_Store
Thumbs.db
*~

# IDE & Editor Settings
.vscode/
.idea/
*.swp
*.swo

# Datasets and Raw Data
# Highly important to ignore all raw and processed image blobs
data/raw/
data/processed/
data/preprocessed/
data/**/*.jpg
data/**/*.png
data/**/*.json
data/**/*.txt

# Deep Learning Checkpoints & Weights
checkpoints/
*.pth
*.pt
*.ckpt

# Execution Logs, Metrics & W&B Local Sync
wandb/
logs/
*.log
runs/
tensorboard/
mlruns/

# Dependency & Packaging 
# (Note: we leave pyproject.toml and uv.lock as tracked)
build/
dist/
*.egg-info/

# Jupyter & Typst Temporary files
.ipynb_checkpoints/
*.pdf
.typst_cache/
